# Если приложение открывается не с корня домена, а по пути (например https://metlab-a.ru/knopka):
# NEXT_PUBLIC_BASE_PATH=/knopka
# Тогда в next.config включается basePath; локально переменную не задавай.

# Supabase (обязательно для входа)
# Взять в Dashboard: https://supabase.com/dashboard → проект → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://ВАШ_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ваш_anon_key

# Синхронизация кабинета с облаком: один раз выполни SQL из supabase/migrations/001_knopka_workspace.sql
# в SQL Editor проекта (см. supabase/README.md).

# Только локально: открывать весь кабинет /app/* без входа (обход страницы логина при проверке экранов)
# НЕ включать на продакшене.
# NEXT_PUBLIC_KNOPKA_DEV_SKIP_AUTH=1

# Cloudflare Turnstile (капча на /login и /sign-up). Без ключей — предупреждение на странице, вход не блокируется.
# Dashboard: https://dash.cloudflare.com/ → Turnstile → создать виджет → Site Key + Secret.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# GigaChat (чат на странице /app/strategy). Ключ авторизации из личного кабинета Сбер — «Настройка API».
# GIGACHAT_AUTHORIZATION_KEY=
# Опционально: GIGACHAT_API_SCOPE=GIGACHAT_API_PERS (по умолчанию для физлиц)
# Опционально: GIGACHAT_MODEL=GigaChat | GigaChat-Pro | GigaChat-Max (см. тариф и документацию Сбера)
