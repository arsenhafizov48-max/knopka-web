# ОБЯЗАТЕЛЬНО на Vercel, если в браузере URL вида https://домен/кнопка/app/... или .../knopka/...
# (иначе fetch на /кнопка/api/... получит HTML 404 — приложение собрано без basePath).
# Значение = тот же префикс, что в адресной строке (латиница или кириллица как у вас в URL):
# NEXT_PUBLIC_BASE_PATH=/кнопка
# или NEXT_PUBLIC_BASE_PATH=/knopka
# После добавления переменной — новый деплой (Redeploy). Локально не задавай, если открываешь с корня localhost.

# Supabase (обязательно для входа)
# Взять в Dashboard: https://supabase.com/dashboard → проект → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://ВАШ_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ваш_anon_key

# Service Role — только на сервере (Vercel). Settings → API → service_role. Нужен для Яндекс.Директа OAuth (запись токенов в таблицу без доступа из браузера).
# SUPABASE_SERVICE_ROLE_KEY=

# Яндекс Директ — OAuth на пользователя (раздел «Каналы»). В приложении Яндекс OAuth укажи Redirect URI = твой домен + путь /auth/yandex-direct/callback (с учётом NEXT_PUBLIC_BASE_PATH, если он есть).
# YANDEX_DIRECT_OAUTH_CLIENT_ID=
# YANDEX_DIRECT_OAUTH_CLIENT_SECRET=
# Опционально: зафиксировать redirect URI (если не задано — берётся origin запроса + basePath + /auth/yandex-direct/callback)
# YANDEX_DIRECT_OAUTH_REDIRECT_URI=https://ваш-домен.ru/auth/yandex-direct/callback

# Синхронизация кабинета с облаком: один раз выполни SQL из supabase/migrations/001_knopka_workspace.sql
# в SQL Editor проекта (см. supabase/README.md).

# Только локально: открывать весь кабинет /app/* без входа (обход страницы логина при проверке экранов)
# НЕ включать на продакшене.
# NEXT_PUBLIC_KNOPKA_DEV_SKIP_AUTH=1

# Cloudflare Turnstile (капча на /login и /sign-up). Без ключей — предупреждение на странице, вход не блокируется.
# Dashboard: https://dash.cloudflare.com/ → Turnstile → создать виджет → Site Key + Secret.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Яндекс Вордстат API (серверный OAuth access token). Подключение: https://yandex.com/support2/wordstat/ru/content/api-wordstat
# Не использовать NEXT_PUBLIC_* — токен только на сервере.
# YANDEX_WORDSTAT_OAUTH_TOKEN=
#
# Одноразовый обмен кода на токен (только локально, не коммитить .env.local):
# YANDEX_OAUTH_CLIENT_ID=
# YANDEX_OAUTH_CLIENT_SECRET=
# YANDEX_OAUTH_CODE=
# YANDEX_OAUTH_REDIRECT_URI=https://oauth.yandex.ru/verification_code
# Затем: npm run wordstat:exchange-token

# GigaChat (чат на странице /app/strategy). Ключ авторизации из личного кабинета Сбер — «Настройка API».
# GIGACHAT_AUTHORIZATION_KEY=
# Опционально: GIGACHAT_API_SCOPE=GIGACHAT_API_PERS (по умолчанию для физлиц)
# Опционально: GIGACHAT_MODEL=GigaChat | GigaChat-Pro | GigaChat-Max (см. тариф и документацию Сбера)
